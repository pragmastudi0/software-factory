        "jsonBody": "={{ JSON.stringify({ chat_id: parseInt($env.TELEGRAM_ADMIN_CHAT_ID || '0'), text: '\u274c *Validaci\u00f3n Fallida*\\n\\nSe agotaron los reintentos de correcci\u00f3n autom\u00e1tica\\. Proyecto marcado como `failed`\\. Revisa los logs en n8n y corrige manualmente o ajusta los patrones de error\\.', parse_mode: 'MarkdownV2' }) }}",
        "options": {
          "ignore400": true
        }
      },
      "id": "validation-notify-fail-01",
      "name": "Notify: Build Failed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        3000,
        360
      ]
    }
  ],
