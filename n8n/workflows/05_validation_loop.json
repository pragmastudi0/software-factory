      "typeVersion": 1,
      "position": [
        2880,
        400
      ]
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "mode": "name",
          "value": "05 - Validation Loop"
        },
        "options": {
          "waitForSubWorkflow": false
