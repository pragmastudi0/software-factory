        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "",
              "value": "={{ JSON.stringify({ status: 'failed' }) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "valid-mark-failed-16",
      "name": "Mark Project Failed",
      "type": "n8n-nodes-base.httpRequest",
