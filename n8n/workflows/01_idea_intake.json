      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'accepted', project_id: $('Parse PRD Response').first().json.project_id, message: 'Your app is being built! Check back soon.' }) }}",
        "options": {
