      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: parseInt($env.TELEGRAM_ADMIN_CHAT_ID || '0'), text: '\ud83d\ude80 *Proyecto Creado\\!*\\n\\n' + '\ud83d\udccb Idea: ' + ($('Build PRD Prompt').first().json.idea || '').slice(0,80) + '\\n\\n' + '\ud83d\udd18 Estado: intake \u2192 setup\\n' + '\ud83c\udd94 `' + $('Build PRD Prompt').first().json.project_id + '`\\n\\n' + '_El pipeline de 9 agentes iniciar\u00e1 en breve\\._ ', parse_mode: 'MarkdownV2', disable_notification: false }) }}",
        "options": {
          "ignore400": true
        }
      },
      "id": "intake-notify-tg-11",
      "name": "Notify: Project Created",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
