{
  "name": "01 - Idea Intake",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "intake",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "intake-webhook-01",
      "name": "Receive Idea",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "webhookId": "intake-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst idea = (body.idea || '').trim();\nconst userEmail = (body.user_email || '').trim();\nlet projectName = (body.project_name || '').trim();\n\nif (!idea || idea.length < 10) {\n  throw new Error('Idea must be at least 10 characters long');\n}\nif (idea.length > 5000) {\n  throw new Error('Idea must be under 5000 characters');\n}\n\nif (!projectName) {\n  // Auto-generate from first 5 meaningful words of idea\n  projectName = idea.split(' ').slice(0, 5).join(' ');\n}\n\n// Generate URL-safe slug\nconst slug = projectName\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s-]/g, '')\n  .replace(/\\s+/g, '-')\n  .replace(/-+/g, '-')\n  .slice(0, 50)\n  .replace(/^-|-$/g, '')\n  + '-' + Date.now().toString(36);\n\nreturn [{ json: { idea, user_email: userEmail, project_name: projectName, slug, timestamp: new Date().toISOString() } }];"
      },
      "id": "intake-validate-02",
      "name": "Validate and Sanitize Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/projects",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "",
              "value": "={{ JSON.stringify({ name: $json.project_name, slug: $json.slug, raw_idea: $json.idea, status: 'intake' }) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "intake-create-project-03",
      "name": "Create Project Record",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const project = $input.first().json[0];\nconst idea = $('Validate and Sanitize Input').first().json.idea;\n\n// Read product-manager system prompt (embedded as string)\nconst systemPrompt = `You are a senior Product Manager AI. Transform the user's app idea into a complete PRD. Return ONLY a single valid JSON object matching the schema exactly. No markdown, no explanation outside JSON.`;\n\nconst userPrompt = `Create a complete Product Requirements Document for this app idea:\\n\\n\"${idea}\"\\n\\nReturn the JSON structure as specified in your instructions.`;\n\nconst geminiPayload = {\n  contents: [{ role: 'user', parts: [{ text: userPrompt }] }],\n  systemInstruction: { parts: [{ text: systemPrompt }] },\n  generationConfig: {\n    temperature: 0.4,\n    maxOutputTokens: 8192,\n    responseMimeType: 'application/json'\n  }\n};\n\nreturn [{ json: { project_id: project.id, project_slug: project.slug, gemini_payload: geminiPayload, idea } }];"
      },
      "id": "intake-build-prd-prompt-04",
      "name": "Build PRD Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/{{ $env.GEMINI_PRO_MODEL }}:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.gemini_payload) }}",
        "options": {
          "timeout": 120000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "waitBetweenTries": 5000
          }
        }
      },
      "id": "intake-gemini-prd-05",
      "name": "Gemini: Generate PRD",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const geminiResponse = $input.first().json;\nconst rawText = geminiResponse.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n\nlet prdData;\ntry {\n  prdData = JSON.parse(rawText);\n} catch (e) {\n  // Try to extract JSON from the response\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    prdData = JSON.parse(jsonMatch[0]);\n  } else {\n    prdData = { prd: { title: 'Project', tech_stack: {}, user_stories: [], objectives: [], risks: [], roadmap: [] } };\n  }\n}\n\nconst prd = prdData.prd || prdData;\nconst project_id = $('Build PRD Prompt').first().json.project_id;\nconst project_slug = $('Build PRD Prompt').first().json.project_slug;\n\nreturn [{\n  json: {\n    project_id,\n    project_slug,\n    prd_content: rawText,\n    user_stories: prd.user_stories || [],\n    objectives: prd.objectives || [],\n    risks: prd.risks || [],\n    roadmap: prd.roadmap || [],\n    tech_stack: prd.tech_stack || {}\n  }\n}];"
      },
      "id": "intake-parse-prd-06",
      "name": "Parse PRD Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/requirements",
        "sendHeaders": true,
        "headerParameters": {
