# ═══════════════════════════════════════════════════════════
#  AUTONOMOUS SOFTWARE FACTORY — Environment Variables
#  Copy to .env and fill in ALL values before running setup.sh
# ═══════════════════════════════════════════════════════════

# ── n8n Internal Database (local Postgres — NOT Supabase)
N8N_DB_POSTGRESDB_USER=n8n
N8N_DB_POSTGRESDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_DB_POSTGRESDB_DATABASE=n8n

# ── n8n Application
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE
N8N_PORT=5678
# Public URL where n8n webhooks are reachable (used for callbacks from GitHub, Vercel)
N8N_WEBHOOK_URL=https://your-n8n-domain.com/

# ── Google AI Studio / Gemini
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash-exp
# Used for large context PRD/architecture tasks:
GEMINI_PRO_MODEL=gemini-1.5-pro-latest

# ── OpenRouter (free-tier fallback LLM)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free

# ── OpenHands
OPENHANDS_PORT=3000
OPENHANDS_API_KEY=CHANGE_ME_OPENHANDS_SECRET
OPENHANDS_LLM_MODEL=gemini/gemini-2.0-flash-exp
OPENHANDS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENHANDS_FALLBACK_LLM_MODEL=openrouter/google/gemini-2.0-flash-exp:free
SANDBOX_USER_ID=1000

# ── GitHub
GITHUB_TOKEN=ghp_...
# Fine-grained PAT scopes required: repo, issues, workflows, pull_requests
GITHUB_ORG=your-github-org
GITHUB_DEFAULT_BRANCH=main

# ── Supabase (remote project, not self-hosted)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...
SUPABASE_ANON_KEY=eyJh...

# ── Vercel
VERCEL_TOKEN=...
VERCEL_TEAM_ID=team_...
VERCEL_ORG_ID=...

# ── Playwright / QA
PLAYWRIGHT_TIMEOUT=30000

# ── Telegram Bot (primary user interface)
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated list of Telegram chat IDs allowed to control the factory
# Get your chat ID by messaging @userinfobot
TELEGRAM_ALLOWED_USERS=123456789,987654321
# Chat ID to receive broadcast notifications (usually same as your own chat ID)
TELEGRAM_ADMIN_CHAT_ID=123456789

# ── Notifications (optional — leave blank to skip)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── Factory Behavior
FACTORY_MAX_CODE_FIX_RETRIES=3
FACTORY_MAX_QA_FIX_RETRIES=3
FACTORY_AGENT_TIMEOUT_SECONDS=300
